VITE_APP_URL="http://localhost:8000"
VITE_API_BASE_URL="/api"
VITE_API_TIMEOUT="15000"
VITE_API_WITH_CREDENTIALS="false"
VITE_API_PRODUCTS_PATH="/products"
VITE_API_CATEGORIES_PATH="/categories"
VITE_API_LOGIN_PATH="/auth/login"
VITE_API_ORDERS_PATH="/orders"

# Users API: path (dùng với VITE_API_BASE_URL) hoặc full URL
# Dev (cùng máy): để mặc định /users, Vite proxy sẽ gửi /api/users -> localhost:8080/users
# Deploy: set VITE_API_BASE_URL="https://api.tenmien.com" hoặc VITE_API_USERS_URL="https://api.tenmien.com/users"
VITE_API_USERS_PATH="/users"
# VITE_API_USERS_URL="http://localhost:8080/users"

# Dev: backend chạy ở port khác thì set (ví dụ 8081)
# VITE_PROXY_TARGET="http://localhost:8081"
